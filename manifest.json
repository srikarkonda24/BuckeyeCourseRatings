{
  "manifest_version": 3,
  "name": "BuckeyeCourseRatings",
  "version": "1.0.0",
  "description": "See RateMyProfessors ratings and reviews directly on the Ohio State University class search page. No more switching tabs.",
  "minimum_chrome_version": "102",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background/index.js"
  },
  "content_scripts": [
    {
      "matches": ["https://classes.osu.edu/*"],
      "js": [
        "src/shared/constants.js",
        "src/shared/utils.js",
        "src/content/scraper.js",
        "src/content/tooltip.js",
        "src/content/injector.js",
        "src/content/index.js"
      ],
      "css": ["src/styles/badge.css"]
    }
  ],
  "permissions": ["storage"],
  "host_permissions": [
    "https://classes.osu.edu/*",
    "https://www.ratemyprofessors.com/*"
  ]
}
